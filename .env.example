## Required
# Congress.gov API key (issued via api.data.gov)
CONGRESS_GOV_API_KEY=YOUR_API_KEY_HERE

## Optional: api.data.gov gateway key passing mode
# query (default)  -> api_key=... query parameter
# header           -> X-Api-Key: ... header (customizable)
# basic            -> HTTP Basic Auth username = api key (empty password)
CONGRESS_GOV_API_KEY_MODE=query
CONGRESS_GOV_API_KEY_HEADER_NAME=X-Api-Key

## Optional: override upstream API base URL & timeout
CONGRESS_GOV_API_URL=https://api.congress.gov/v3
CONGRESS_GOV_API_TIMEOUT=30000

## Optional: local rate limiter (estimate, not authoritative)
RATE_LIMIT_MAX_REQUESTS=5000
RATE_LIMIT_PER_HOURS=1
ENABLE_BACKOFF=true

## Optional: JSON config path (see README)
# CONGRESS_GOV_CONFIG_PATH=./config.local.json
